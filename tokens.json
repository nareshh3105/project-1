{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "name": "OBS CodeBuilders UI Kit",
    "version": "1.0.0",
    "description": "Design tokens for OBS Studio-inspired desktop UI, Code Builders neon gradient theme"
  },
  "color": {
    "$type": "color",
    "bg": {
      "base":    { "$value": "#0B0B0F", "$description": "App root background" },
      "surface": { "$value": "#14141C", "$description": "Card / panel surface" },
      "panel":   { "$value": "#1C1C27", "$description": "Dock panel fill" },
      "divider": { "$value": "#2A2A3A", "$description": "Border / separator" }
    },
    "text": {
      "primary":   { "$value": "#FFFFFF" },
      "secondary": { "$value": "#B9B9C9" },
      "muted":     { "$value": "#6C6C80" }
    },
    "accent": {
      "start": { "$value": "#8A5CFF", "$description": "Gradient start — purple" },
      "end":   { "$value": "#FF4FD8", "$description": "Gradient end — magenta" }
    },
    "state": {
      "hover":   { "$value": "rgba(255,255,255,0.06)" },
      "active":  { "$value": "rgba(138,92,255,0.18)" },
      "danger":  { "$value": "#FF5470" },
      "warning": { "$value": "#FFC857" },
      "success": { "$value": "#3DDC97" }
    },
    "meter": {
      "safe":    { "$value": "#3DDC97", "$description": "< -20 dBFS" },
      "caution": { "$value": "#FFC857", "$description": "-20 to -6 dBFS" },
      "clip":    { "$value": "#FF5470", "$description": "> -6 dBFS" }
    }
  },
  "gradient": {
    "accent-primary": {
      "$type": "string",
      "$value": "linear-gradient(135deg, #8A5CFF 0%, #FF4FD8 100%)",
      "$description": "Primary brand gradient — buttons, active states, glows"
    },
    "accent-subtle": {
      "$type": "string",
      "$value": "linear-gradient(135deg, rgba(138,92,255,0.15) 0%, rgba(255,79,216,0.15) 100%)"
    }
  },
  "typography": {
    "$type": "typography",
    "heading-xl": {
      "$value": { "fontFamily": "Inter", "fontWeight": "600", "fontSize": "24", "lineHeight": "32" }
    },
    "heading-lg": {
      "$value": { "fontFamily": "Inter", "fontWeight": "500", "fontSize": "22", "lineHeight": "30" }
    },
    "heading-md": {
      "$value": { "fontFamily": "Inter", "fontWeight": "500", "fontSize": "18", "lineHeight": "26" }
    },
    "panel-title": {
      "$value": { "fontFamily": "Inter", "fontWeight": "500", "fontSize": "15", "lineHeight": "20" }
    },
    "body": {
      "$value": { "fontFamily": "Inter", "fontWeight": "400", "fontSize": "13", "lineHeight": "18" }
    },
    "caption": {
      "$value": { "fontFamily": "Inter", "fontWeight": "400", "fontSize": "11", "lineHeight": "16" }
    },
    "mono": {
      "$value": { "fontFamily": "JetBrains Mono", "fontWeight": "400", "fontSize": "12", "lineHeight": "18" },
      "$description": "Used in log viewer only"
    }
  },
  "spacing": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "12": { "$value": "48px" }
  },
  "borderRadius": {
    "$type": "dimension",
    "panel":  { "$value": "12px" },
    "input":  { "$value": "8px" },
    "button": { "$value": "6px" },
    "pill":   { "$value": "999px" }
  },
  "borderWidth": {
    "$type": "dimension",
    "subtle": { "$value": "1px" },
    "focus":  { "$value": "1.5px" }
  },
  "shadow": {
    "$type": "shadow",
    "panel": {
      "$value": {
        "offsetX": "0", "offsetY": "1", "blur": "2", "spread": "0",
        "color": "rgba(0,0,0,0.35)"
      }
    },
    "float": {
      "$value": {
        "offsetX": "0", "offsetY": "12", "blur": "32", "spread": "0",
        "color": "rgba(0,0,0,0.55)"
      }
    },
    "glow": {
      "$value": {
        "offsetX": "0", "offsetY": "0", "blur": "18", "spread": "0",
        "color": "rgba(138,92,255,0.35)"
      },
      "$description": "Accent glow — applied to active buttons, focused inputs"
    },
    "modal": {
      "$value": {
        "offsetX": "0", "offsetY": "24", "blur": "64", "spread": "0",
        "color": "rgba(0,0,0,0.65)"
      }
    }
  },
  "size": {
    "$type": "dimension",
    "icon-sm": { "$value": "16px" },
    "icon-md": { "$value": "20px" },
    "icon-lg": { "$value": "24px" },
    "button-sm": { "$value": "28px" },
    "button-md": { "$value": "32px" },
    "button-lg": { "$value": "40px" },
    "menubar-height":  { "$value": "32px" },
    "toolbar-height":  { "$value": "40px" },
    "statusbar-height":{ "$value": "24px" },
    "panel-header":    { "$value": "36px" },
    "dock-min-width":  { "$value": "200px" }
  }
}
